---
interface Props {
  sources: string[];
  tags?: string[];
}

const { sources, tags = [] } = Astro.props;

const sourceLabels: Record<string, string> = {
  hackernews: "黑客新闻",
  lobsters: "龙虾",
  "github-trending": "GitHub 趋势",
  producthunt: "产品猎手",
  devto: "DEV 社区",
  changelog: "更新日志",
};
---

<div class="filter-bar" id="filter-bar">
  <button class="filter-btn active" data-filter="all">全部</button>
  {sources.map((s) => (
    <button class="filter-btn" data-filter={s}>
      {sourceLabels[s] || s}
    </button>
  ))}
</div>

{tags.length > 0 && (
  <div class="filter-bar" id="tag-filter">
    <button class="filter-btn active" data-tag="all">全部标签</button>
    {tags.map((t) => (
      <button class="filter-btn" data-tag={t}>{t}</button>
    ))}
  </div>
)}

<script>
  function setupFilters() {
    let activeSource = "all";
    let activeTag = "all";

    function applyFilters() {
      const items = document.querySelectorAll<HTMLElement>(".item-row");
      items.forEach((item) => {
        const source = item.dataset.source || "";
        const tags = item.dataset.tags || "";
        const sourceMatch = activeSource === "all" || source === activeSource;
        const tagMatch = activeTag === "all" || tags.split(",").includes(activeTag);
        item.style.display = sourceMatch && tagMatch ? "" : "none";
      });
    }

    document.getElementById("filter-bar")?.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>(".filter-btn");
      if (!btn) return;
      activeSource = btn.dataset.filter || "all";
      document.querySelectorAll("#filter-bar .filter-btn").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      applyFilters();
    });

    document.getElementById("tag-filter")?.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>(".filter-btn");
      if (!btn) return;
      activeTag = btn.dataset.tag || "all";
      document.querySelectorAll("#tag-filter .filter-btn").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      applyFilters();
    });
  }

  setupFilters();
</script>
