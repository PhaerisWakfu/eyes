---
import Base from "../layouts/Base.astro";
import ItemRow from "../components/ItemRow.astro";
import { getLatestDate, getDailyData } from "../lib/data";

const MAX_DISPLAY = 20;
const latestDate = getLatestDate();
const data = latestDate ? getDailyData(latestDate) : null;
const rawItems = data?.items ?? [];
const items = [...rawItems]
  .sort((a, b) => ((b as { valueScore?: number }).valueScore ?? 0) - ((a as { valueScore?: number }).valueScore ?? 0))
  .slice(0, MAX_DISPLAY);
---

<Base title={latestDate ? `Eyes — ${latestDate}` : "Eyes"}>
  <div id="day-content" data-ssr-date={latestDate ?? ""}>
    {items.length > 0 ? (
      <ol class="item-list">
        {items.map((item, idx) => (
          <ItemRow rank={idx + 1} item={item} />
        ))}
      </ol>
    ) : (
      <p class="empty-state">加载中…</p>
    )}
  </div>
  <script is:inline>
    (function () {
      try {
      const MAX_DISPLAY = 20;
      const RECENT_DAYS = 3;

      function fmt(d) {
        return d.toISOString().slice(0, 10);
      }
      function dates() {
        const t = new Date();
        const yesterday = new Date(t);
        yesterday.setDate(yesterday.getDate() - 1);
        const out = [];
        for (let i = 0; i < RECENT_DAYS; i++) {
          const d = new Date(yesterday);
          d.setDate(d.getDate() - i);
          out.push(fmt(d));
        }
        return out;
      }

      const recentDates = dates();
      let targetDate = recentDates[0];

      const contentEl = document.getElementById("day-content");
      const navEl = document.querySelector(".date-switch");
      if (!contentEl) return;

      function esc(s) {
        if (s == null) return "";
        const d = document.createElement("div");
        d.textContent = String(s);
        return d.innerHTML;
      }
      function domain(u) {
        try { return new URL(u).hostname.replace(/^www\./, ""); } catch { return ""; }
      }

      function setActive(d) {
        targetDate = d;
        if (navEl) {
          navEl.querySelectorAll(".date-pill").forEach((a) => {
            const isActive = a.getAttribute("data-date") === d;
            a.classList.toggle("active", isActive);
            a.setAttribute("aria-current", isActive ? "date" : null);
          });
        }
      }

      function renderPills() {
        if (!navEl) return;
        navEl.innerHTML = recentDates.map((d) => {
          const isActive = d === targetDate;
          return `<a href="#" role="button" data-date="${esc(d)}" class="date-pill${isActive ? " active" : ""}" ${isActive ? 'aria-current="date"' : ""}>${d}</a>`;
        }).join("");
        navEl.querySelectorAll(".date-pill").forEach((a) => {
          a.addEventListener("click", (e) => {
            e.preventDefault();
            const d = a.getAttribute("data-date");
            if (d) {
              setActive(d);
              loadDate(d);
            }
          });
        });
      }

      async function loadDate(d) {
        try {
        async function fetchAndParse(url) {
          const r = await fetch(url);
          if (!r.ok) return null;
          const text = await r.text();
          if (!text || !text.trim()) return null;
          try { return JSON.parse(text); } catch { return null; }
        }
        let data = await fetchAndParse(`/data/enriched/${d}.json`);
        if (!data) data = await fetchAndParse(`/data/raw/${d}.json`);
        if (!data) {
          contentEl.innerHTML = `<div class="empty-state"><p><strong>${esc(d)} 暂无数据</strong></p></div>`;
          return;
        }
        const { items = [] } = data;
        const sorted = [...items].sort((a, b) => (b.valueScore ?? 0) - (a.valueScore ?? 0)).slice(0, MAX_DISPLAY);

        const imgUrl = (item) => {
          if (!item.image) return null;
          if (item.image.startsWith("http")) return item.image;
          return "/data/" + item.image;
        };
        const html = sorted.length
          ? "<ol class=\"item-list\">" + sorted.map((item, idx) => {
              const title = item.title_zh || item.title;
              const summary = item.summary_zh || (item.description ? item.description.slice(0, 80) + (item.description.length > 80 ? "…" : "") : "暂无简介");
              const tags = (item.tags || []).map(t => `<span class="tag">${esc(t)}</span>`).join("");
              const dom = domain(item.url);
              const img = imgUrl(item);
              const imgHtml = img ? `<div class="item-image"><img src="${esc(img)}" alt="" loading="lazy" /></div>` : "";
              return `<li class="item-row"><div class="item-main"><span class="item-rank">${idx + 1}.</span><a href="${esc(item.url)}" target="_blank" rel="noopener" class="item-title">${esc(title)}</a>${dom ? ` <span class="item-domain">(${esc(dom)})</span>` : ""}</div>${imgHtml}<div class="item-summary">${esc(summary)}</div>${tags ? `<div class="item-tags">${tags}</div>` : ""}</li>`;
            }).join("") + "</ol>"
          : `<div class="empty-state"><p><strong>${esc(d)} 暂无数据</strong></p></div>`;

        contentEl.innerHTML = html;
        document.title = `Eyes — ${d}`;
        } catch (err) {
          contentEl.innerHTML = `<div class="empty-state"><p>加载失败，请刷新重试</p><p style="font-size:11px;color:#999">${esc(err && err.message || String(err))}</p></div>`;
        }
      }

      renderPills();
      loadDate(targetDate);
      } catch (e) {
        var el = document.getElementById("day-content");
        if (el) el.innerHTML = '<div class="empty-state"><p>加载失败，请刷新重试</p><p style="font-size:11px;color:#999">' + (e && e.message ? e.message : '') + '</p></div>';
        console.error(e);
      }
    })();
  </script>
</Base>
