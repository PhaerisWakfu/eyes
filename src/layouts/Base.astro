---
import "../styles/global.css";

interface Props {
  title?: string;
  currentDate?: string;
  recentDates?: string[];
}

const { title = "Eyes", currentDate, recentDates = [] } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a href="/" class="logo">Eyes</a>
        {recentDates.length > 0 && (
          <nav class="date-switch" aria-label="最近日报">
            {recentDates.map((d) => (
              <a
                href={`/day/${d}`}
                class={d === currentDate ? "date-pill active" : "date-pill"}
                aria-current={d === currentDate ? "date" : undefined}
              >
                {d}
              </a>
            ))}
          </nav>
        )}
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        Eyes — 技术洞察与商业模式聚合
      </div>
    </footer>
  </body>
</html>
